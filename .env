# Настройки сервера
PROJECT_NAME="Junior Backend Service"
HOST="0.0.0.0"
PORT=8000

# Настройки базы данных
DATABASE_URL="sqlite:///./db.sqlite3"

# Настройки ИИ (OpenAI или DeepSeek API)
OPENAI_API_KEY="your-api-key-here"

# Настройки SMTP Yandex для отправки писем
SENDER_EMAIL="your-yandex-email@yandex.ru"
SENDER_PASSWORD="your-app-password" # Это специальный пароль приложения, не основной!
OWNER_EMAIL="your-yandex-email@yandex.ru" # Кому будут приходить заявки